{
  "name": "rust-cloudflare-fullstack-starter",
  "account_id": "e38fd6d9610cdbf2769a474ded929ff8",
  "main": "worker/build/index.js",
  "compatibility_date": "2026-04-01",
  "build": {
    "command": "worker-build --release worker",
    "watch_dir": ["./worker/src", "./shared/src", "./frontend/dist"]
  },
  "assets": {
    "directory": "./frontend/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
